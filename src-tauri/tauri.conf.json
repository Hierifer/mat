{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Materm",
  "version": "0.2.1",
  "identifier": "com.neohex.mat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5178",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Terminal",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "dragDropEnabled": false,
        "transparent": true
      }
    ],
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": null,
      "capabilities": ["default", "updater"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "copyright": "Copyright © 2024 Hierifer. All rights reserved.",
    "shortDescription": "A modern terminal emulator built with Tauri and Vue.",
    "longDescription": "Materm is a cross-platform terminal emulator featuring split panes, tab management, voice input, and auto-update support.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "entitlements": "entitlements.plist",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "-",
      "infoPlist": "Info.plist"
    },
    "linux": {
      "deb": {
        "files": {}
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": true,
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": ["English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Hierifer/mat/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2NERBRUJEOTY5MURGMTEKUldRUjM1R1d2YTVOOXZiYWthZzJxTHM0VE1ZWUdqK2txM2Jqc2pxbzBMQmw4aUlmdldZUzdrM1EK"
    }
  }
}
