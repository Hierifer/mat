<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox (required for App Store) -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Allow the app to access the microphone -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Network access for updates -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow JIT for WebView (needed for Tauri) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Disable library validation (needed for Tauri) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allow spawning child processes (needed for terminal/PTY) -->
    <key>com.apple.security.temporary-exception.sbpl</key>
    <string>(allow process-fork process-exec)</string>
</dict>
</plist>
