{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mat",
  "version": "0.1.12",
  "identifier": "com.hierifer.mat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5178",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Terminal",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "dragDropEnabled": false,
        "transparent": true
      }
    ],
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": ""
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": true
    }
  }
}
