{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Terminal Emulator",
  "version": "0.1.0",
  "identifier": "com.terminal.emulator",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5178",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "label": "main",
      "title": "Terminal",
      "width": 1200,
      "height": 800,
      "minWidth": 800,
      "minHeight": 600,
      "decorations": false,
      "titleBarStyle": "Overlay"
    }],
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
