{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mat",
  "version": "0.1.3",
  "identifier": "com.hierifer.mat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5178",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Terminal",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "dragDropEnabled": false,
        "radius": 16,
        "decorations": false, // 关闭系统标题栏（必须关才能看到圆角）
        "transparent": true // 开启透明（必须开才能显示圆角）
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": ""
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": true
    }
  }
}
