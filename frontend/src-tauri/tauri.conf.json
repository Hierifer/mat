{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mat",
  "version": "0.1.1",
  "identifier": "com.hierifer.mat",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5178",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "label": "main",
      "title": "Terminal",
      "width": 1200,
      "height": 800,
      "minWidth": 800,
      "minHeight": 600,
      "decorations": false,
      "titleBarStyle": "Overlay"
    }],
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": ""
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": true
    }
  }
}
