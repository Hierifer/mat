{
  "name": "frontend",
  "private": true,
  "version": "0.1.19",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "WHISPER_DONT_GENERATE_BINDINGS=1 WHISPER_NO_AVX=1 WHISPER_NO_AVX2=1 WHISPER_NO_FMA=1 WHISPER_NO_F16C=1 tauri dev",
    "tauri:build": "WHISPER_DONT_GENERATE_BINDINGS=1 WHISPER_NO_AVX=1 WHISPER_NO_AVX2=1 WHISPER_NO_FMA=1 WHISPER_NO_F16C=1 tauri build",
    "build:mac": "WHISPER_DONT_GENERATE_BINDINGS=1 WHISPER_NO_AVX=1 WHISPER_NO_AVX2=1 WHISPER_NO_FMA=1 WHISPER_NO_F16C=1 tauri build --target universal-apple-darwin",
    "build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-i18n": "^9.14.4",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@tauri-apps/cli": "^2.9.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "pnpm": "^9.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vue-tsc": "^3.2.5"
  }
}